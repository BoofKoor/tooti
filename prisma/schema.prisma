generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Auth.js (Prisma adapter) ----------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts    Account[]
  sessions    Session[]
  progress    Progress?
  completions LessonCompletion[]
  medals      UserMedal[]
  dailyXp     DailyXp[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ---------- App data ----------
model Progress {
  id             String    @id @default(cuid())
  userId         String    @unique
  xp             Int       @default(0)
  streak         Int       @default(0)
  lastActiveDate DateTime?
  dailyGoal      Int       @default(20) // XP/day; options 10/20/30/50 (Phase 4)
  timezone       String? // IANA tz captured from the browser; fallback handled in code
  correctAnswers Int       @default(0) // lifetime correct answers (drives the 40-questions medal)
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum LessonKind {
  LESSON
  REVIEW
  SECTION_TEST
  STORY
  SPEAKING
}

enum ExerciseType {
  MCQ
  FILL_BLANK
  WORD_BANK
  TRANSLATE
  LISTEN
}

model Unit {
  id         String   @id @default(cuid())
  slug       String   @unique
  title      String
  order      Int
  comingSoon Boolean  @default(false) // future topics shown as locked "soon" in the Learn path
  createdAt  DateTime @default(now())

  lessons Lesson[]
}

model Lesson {
  id        String     @id @default(cuid())
  unitId    String
  slug      String     @unique // canonical slug (see Notes re: Learn/Guide divergence)
  title     String
  order     Int
  kind      LessonKind @default(LESSON) // boss/section nodes use SECTION_TEST/STORY/etc.
  createdAt DateTime   @default(now())

  unit        Unit               @relation(fields: [unitId], references: [id], onDelete: Cascade)
  exercises   Exercise[]
  sections    LessonSection[]
  completions LessonCompletion[]

  @@unique([unitId, order])
}

enum SectionKind {
  READING
  CONCEPT
  SUMMARY
  VIDEO
}

model LessonSection {
  id       String      @id @default(cuid())
  lessonId String
  order    Int
  kind     SectionKind
  titleEn  String
  titleFa  String
  content  Json // SectionContent (lib/lesson-content.ts); rendered by Phase 5B

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, order])
}

model Exercise {
  id            String       @id @default(cuid())
  lessonId      String
  order         Int
  type          ExerciseType @default(MCQ)
  instructionEn String // "Choose the correct form."
  instructionFa String // necessary-Persian instruction
  prompt        String // "She ___ coffee every morning."
  options       String[] // MCQ choices / word-bank tokens
  correctIndex  Int? // MCQ
  answer        String? // fill-blank / translate canonical answer (Phase 5)
  explanationFa String // legacy Persian tip (kept; not shown in the English-only runner)
  explanationEn String  @default("") // English grammar tip shown on wrong-answer feedback
  data          Json? // reserved for richer Phase 5 exercise types
  createdAt     DateTime     @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([lessonId, order])
}

// Per-local-day XP ledger — the single source of truth for daily/goal/week views
// (replays credit the day they happen, not the day of first completion).
model DailyXp {
  id     String @id @default(cuid())
  userId String
  day    String // local "YYYY-MM-DD" in the user's tz (computed with localDay)
  xp     Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
}

model LessonCompletion {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  xpEarned    Int      @default(0)
  heartsLeft  Int      @default(0)
  perfect     Boolean  @default(false)
  crownLevel  Int      @default(0) // drives the Learn-path crown; replay rules = Phase 4

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId]) // one row per user+lesson (upsert on replay)
}

enum MedalTier {
  BRONZE
  SILVER
  GOLD
  SPECIAL
}

model Medal {
  id          String    @id @default(cuid())
  key         String    @unique // EXACT components/ui Medal `type` (kebab); see seed
  name        String
  description String
  tier        MedalTier
  order       Int

  users UserMedal[]
}

model UserMedal {
  id       String    @id @default(cuid())
  userId   String
  medalId  String
  progress Int       @default(0) // 0–100 toward earning (drives 'in-progress')
  earnedAt DateTime? // set when earned
  seenAt   DateTime? // when the user first saw this earned medal → drives 'recently'

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  medal Medal @relation(fields: [medalId], references: [id], onDelete: Cascade)

  @@unique([userId, medalId])
}

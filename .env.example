# Copy to .env.local (local dev) or .env and fill in real values.

# Postgres connection string used by Prisma (wired in Phase 3).
# For docker-compose, the host is the `db` service: @db:5432.
DATABASE_URL="postgresql://tooti:tooti@localhost:5432/tooti?schema=public"

# Auth.js secret. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET="replace-me-generate-with-openssl-rand-base64-32"

# Google OAuth (Auth.js auto-reads these names)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email magic-link (SMTP). Leave EMAIL_SERVER EMPTY in dev:
# when empty, the magic link is logged to the server console instead of sent.
EMAIL_SERVER=""                       # e.g. smtp://user:pass@smtp.host:587
EMAIL_FROM="Tooti <login@tooti.academy>"

# Needed behind a reverse proxy / in Docker (harmless locally). Required in Phase 7.
# AUTH_TRUST_HOST="true"

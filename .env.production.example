# Copy to .env on the server and fill in real values. NEVER commit the real .env.

# Strong Postgres password (used by both db and the app's DATABASE_URL).
POSTGRES_PASSWORD="CHANGE_ME_long_random_password"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_openssl_rand_base64_32"

# Public URL (must be https://tooti.academy in production).
AUTH_URL="https://tooti.academy"

# Google OAuth (from Google Cloud Console — see runbook).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Email magic-link via Resend SMTP (see runbook). Username is literally "resend".
EMAIL_SERVER="smtps://resend:re_YOUR_RESEND_API_KEY@smtp.resend.com:465"
EMAIL_FROM="Tooti <login@tooti.academy>"
